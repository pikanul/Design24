Options -Indexes -ExecCGI

<FilesMatch "\.(?:php[0-9s]?|phtml|phar|cgi|pl|py|rb|sh|bash|zsh|bat|cmd|exe|dll|com|msi|js|mjs|html?|xhtml|svg)$">
    Require all denied
</FilesMatch>

<IfModule mod_mime.c>
    RemoveHandler .php .phtml .phar .cgi .pl .py .rb .sh .bash .zsh .bat .cmd .js .mjs .html .htm .svg
    RemoveType .php .phtml .phar .cgi .pl .py .rb .sh .bash .zsh .bat .cmd .js .mjs .html .htm .svg
</IfModule>
