# Store the real file outside public_html, for example:
# /home/CPANEL_USERNAME/design24-private/.env

APP_ENV=production
PHP_ERROR_LOG=/home/CPANEL_USERNAME/design24-private/logs/php-error.log

# Choose one database driver.
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpaneluser_design24
DB_USER=cpaneluser_design24user
DB_PASSWORD=replace-with-a-strong-password

# SQLite alternative (leave MySQL values unused when selected).
# DATABASE_PATH=/home/CPANEL_USERNAME/design24-private/design24.sqlite

# Required whenever SMTP credentials are saved or used.
CONSULTATION_SETTINGS_KEY=replace-with-a-long-random-secret
CONSULTATION_ATTACHMENT_DIR=/home/CPANEL_USERNAME/design24-private/consultations

# Optional settings.
# DESIGN24_TRUST_PROXY_HEADERS=1
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
